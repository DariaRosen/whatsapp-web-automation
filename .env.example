# Server
PORT=3000

# MongoDB: connection string and optional database name
MONGO_URL=mongodb://localhost:27017
DB_NAME=whatsapp-leads

# Optional: path for WhatsApp session data (defaults to .wwebjs_auth in project root)
# Use a persistent disk path on Render, e.g. /data/.wwebjs_auth
# WWEBJS_AUTH_PATH=.wwebjs_auth
