# Server
PORT=3000

# MongoDB: connection string and optional database name
MONGO_URL=mongodb://localhost:27017
DB_NAME=whatsapp-leads

# Optional: protect dashboard + API (sign in at /login, or x-dashboard-token header)
# DASHBOARD_TOKEN=your-long-random-secret
# Stricter: reject ?token= in URL (use /login only; breaks old bookmarked links with token)
# DASHBOARD_DISABLE_QUERY_TOKEN=1

# Optional: path for WhatsApp session data (defaults to .wwebjs_auth in project root)
# Use a persistent disk path on Render, e.g. /data/.wwebjs_auth
# WWEBJS_AUTH_PATH=.wwebjs_auth
